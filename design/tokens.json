{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Task Monsters — extracted from gettaskmonsters.com (style.css + live audit Jun 2026). Source: production site, not UNI defaults.",
  "$source": "https://gettaskmonsters.com/assets/css/style.css",
  "color": {
    "blue": {
      "500": { "$value": "#007AFF", "$type": "color", "$description": "Primary brand — CTAs, icons, links, sticky header" },
      "400": { "$value": "#3D9BFF", "$type": "color" },
      "300": { "$value": "#C1EAFA", "$type": "color", "$description": "Gradient end (gradient-overly)" },
      "100": { "$value": "#E8F4FF", "$type": "color", "$description": "Light blue tint surfaces" }
    },
    "neutral": {
      "white": { "$value": "#FFFFFF", "$type": "color", "$description": "Page + card surfaces" },
      "grey-50": { "$value": "#F6F6F6", "$type": "color", "$description": "bg-grey sections" },
      "grey-100": { "$value": "#F6FAFB", "$type": "color" },
      "grey-200": { "$value": "#EEEEEE", "$type": "color", "$description": "Borders" },
      "grey-800": { "$value": "#383838", "$type": "color", "$description": "Section headings on white" },
      "grey-900": { "$value": "#333333", "$type": "color", "$description": "Body text" },
      "black": { "$value": "#1D1D1D", "$type": "color", "$description": "Footer bg-black — not pure #000" }
    },
    "safety": {
      "green": { "$value": "#28A745", "$type": "color", "$description": "GREEN tag (Bootstrap success on site)" },
      "amber": { "$value": "#FFC107", "$type": "color", "$description": "AMBER tag" },
      "red": { "$value": "#DC3545", "$type": "color", "$description": "RED tag" }
    },
    "text": {
      "primary": { "$value": "#333333", "$type": "color" },
      "heading": { "$value": "#383838", "$type": "color" },
      "onBlue": { "$value": "#FFFFFF", "$type": "color", "$description": "Hero white-text" },
      "muted": { "$value": "#868E96", "$type": "color" }
    }
  },
  "font": {
    "display": { "$value": "Lato, sans-serif", "$type": "fontFamily", "$description": "Site primary — headings + body" },
    "body": { "$value": "Lato, sans-serif", "$type": "fontFamily" },
    "alt": { "$value": "Raleway, sans-serif", "$type": "fontFamily", "$description": "Imported on site, secondary use only" }
  },
  "fontSize": {
    "hero-h1": { "$value": "clamp(25px, 4.5vw, 45px)", "$type": "dimension", "$description": "Live: 45px / 800 weight" },
    "hero-h2": { "$value": "clamp(22px, 3vw, 30px)", "$type": "dimension", "$description": "Price hook NO SUBSCRIPTION / $9.99" },
    "section-h2": { "$value": "clamp(26px, 3.5vw, 34px)", "$type": "dimension", "$description": "UPPERCASE section titles" },
    "card-h4": { "$value": "20px", "$type": "dimension" },
    "body": { "$value": "16px", "$type": "dimension" },
    "body-lead": { "$value": "18px", "$type": "dimension", "$description": "Hero paragraph live: 18px" }
  },
  "spacing": {
    "section-y": { "$value": "120px", "$type": "dimension", "$description": "section-ptb live" },
    "section-y-tablet": { "$value": "80px", "$type": "dimension" },
    "section-y-mobile": { "$value": "70px", "$type": "dimension" },
    "container": { "$value": "1140px", "$type": "dimension", "$description": "Bootstrap container" },
    "gutter": { "$value": "15px", "$type": "dimension" }
  },
  "radius": {
    "button": { "$value": "30px", "$type": "dimension", "$description": "download-buttons .button pill" },
    "icon": { "$value": "50%", "$type": "dimension", "$description": "feature-icon circles" }
  },
  "gradient": {
    "hero": { "$value": "linear-gradient(to bottom, #007AFF 0%, #C1EAFA 100%)", "$type": "string" }
  }
}
